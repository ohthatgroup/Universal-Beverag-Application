{
  "name": "universal-beverage-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "db:types:generate": "node scripts/generate-db-types.cjs",
    "db:types:check": "node scripts/generate-db-types.cjs --check",
    "db:reset": "bash scripts/run-psql.sh -f scripts/reset-public.sql",
    "db:migrate": "bash scripts/run-psql.sh -f supabase/migrations/202602180001_init.sql && bash scripts/run-psql.sh -f supabase/migrations/202602180002_seed.sql && bash scripts/run-psql.sh -f supabase/migrations/202602190001_customer_portal_tokens.sql && bash scripts/run-psql.sh -f supabase/migrations/202602190002_product_pack_fields.sql && bash scripts/run-psql.sh -f supabase/migrations/202602190003_pack_backfill_cleanup.sql && bash scripts/run-psql.sh -f supabase/migrations/202602190004_storage_images_bucket.sql",
    "db:verify": "bash scripts/run-psql.sh -f scripts/verify-schema.sql",
    "db:provision": "tsx scripts/provision-users.ts",
    "verify:rls": "tsx scripts/verify-rls.ts",
    "ci:prepare-db": "npm run db:reset && npm run db:migrate && npm run db:verify && npm run db:provision"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/nextjs": "^10.39.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.96.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.574.0",
    "next": "^15.5.10",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.10",
    "pg": "^8.18.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
