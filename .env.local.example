# Database URL for local scripts.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Optional ST-6 import-data directory for external JSON exports.
# Expected file names:
# - customers.json
# - customer-product-overrides.json
# - pallet-deals.json
# ST6_IMPORT_INPUT_DIR=./import-data

# Current runtime URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ASSET_BASE_URL=http://localhost:3000
NEON_AUTH_BASE_URL=https://YOUR-BRANCH-ID.neonauth.REGION.aws.neon.tech/DATABASE/auth
NEON_AUTH_COOKIE_SECRET=replace-with-at-least-32-random-characters
NEON_PROJECT_ID=your-neon-project-id
NEON_BRANCH_ID=your-neon-auth-branch-id
NEON_API_KEY=your-neon-api-key
RESEND_API_KEY=re_xxxxxxxxx
INVITES_FROM_EMAIL=mail@your-domain.com

# Deployed environment targets
# Preview typically uses the versioned or preview worker URL returned by:
# npm run deploy:preview
# Production should use the stable workers.dev hostname (or custom domain later).
# PREVIEW_APP_URL=https://<preview-worker>.<subdomain>.workers.dev
# PRODUCTION_APP_URL=https://<production-worker>.<subdomain>.workers.dev

# Free-tier hardening guards (best-effort in-memory limits per Worker/process)
STAFF_INVITE_RATE_LIMIT_MAX=6
STAFF_INVITE_RATE_LIMIT_WINDOW_MS=600000
PORTAL_TOKEN_ROTATION_RATE_LIMIT_MAX=10
PORTAL_TOKEN_ROTATION_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=24
UPLOAD_RATE_LIMIT_WINDOW_MS=300000

# Configure these as Wrangler secrets for deployed Workers
# TURNSTILE_SECRET_KEY=

# Planned Worker bindings (configure in wrangler.jsonc when provisioned)
# HYPERDRIVE
# ASSET_BUCKET

# Ecwid (optional, future integration)
# ECWID_TOKEN=
# ECWID_STORE_ID=
FEATURE_ECWID_PUSH=false

# Sentry (optional)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Workers/OpenNext notes
# - `npm run preview` builds the Next app and previews the Worker locally.
# - `npm run deploy:preview` builds and uploads a preview Worker version URL.
# - `npm run deploy:production` builds and deploys the production Worker.
# - `npm run smoke:deploy` checks the deployed login/reset pages and optional invite/portal URLs.
# - Neon Auth login does not require Supabase variables.
# - `NEON_AUTH_BASE_URL` must point at your Neon-managed auth endpoint, not your app URL.
# - `NEON_AUTH_COOKIE_SECRET` must be stable per environment and at least 32 chars.
# - `NEON_PROJECT_ID`, `NEON_BRANCH_ID`, and `NEON_API_KEY` are required for admin-side customer provisioning.
# - `RESEND_API_KEY` and `INVITES_FROM_EMAIL` are required for dashboard-managed staff invites.
# - Set Wrangler secrets separately for `preview` and `production` with `wrangler secret put <NAME> --env <env>`.
# - Add both the preview and production app URLs as Neon Auth trusted origins before testing live auth flows.
# - Resend must show the sender domain as `verified` before invite/reset email QA should be considered valid.
# - The rate-limit env vars above are optional overrides; the defaults are tuned for the Workers/Resend free-tier pilot.
# - These limits are isolate-local. Move them to a durable store before opening high-volume public traffic.
# - `ST6_IMPORT_INPUT_DIR` is optional and only needed when importing non-catalog ST-6 business data.
# - Configure Neon/Resend password-reset email content to send admins back to `/auth/reset-password` on this app.
