# ─── Supabase ─────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API

# Public keys (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only secret key (NEVER expose to browser — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Ecwid (optional, for future integration) ─────────────────────────────
# ECWID_TOKEN=
# ECWID_STORE_ID=
FEATURE_ECWID_PUSH=false

# ─── Sentry (optional, recommended in production) ──────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── App ──────────────────────────────────────────────────────────────────
# Customer-facing generated links are pinned in code to:
# https://universal-beverag-application.vercel.app
# Do not use localhost for generated production links.
